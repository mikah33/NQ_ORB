// @version=5
// Opening Range Breakout — NQ 5m
// Stop orders at OR levels for precise entry, 1:1 R:R, 1 trade/day
strategy("ORB NQ", overlay=true, max_lines_count=500, max_labels_count=500,
     default_qty_type=strategy.fixed, default_qty_value=1,
     initial_capital=1000, commission_type=strategy.commission.percent, commission_value=0.0)

// ── Inputs ──────────────────────────────────────────────────────────
orMinutes  = input.int(15, "Opening Range (minutes)", minval=5, maxval=60, step=5, tooltip="First N minutes define the range — 15 is standard")
riskPct    = input.float(15.0, "Risk Per Trade (%)", minval=1, maxval=50, step=1) / 100.0
maxSlPts   = input.float(500.0, "Max OR Range (points)", minval=10, step=10, tooltip="Skip if OR range is wider than this")
tpRatio    = input.float(0.75, "TP Ratio (x risk)", minval=0.25, maxval=3.0, step=0.25, tooltip="0.75 = tighter TP, higher win rate")

// ── Session Detection ───────────────────────────────────────────────
inRTH = not na(time(timeframe.period, "0930-1600", "America/New_York"))
isNewSession = inRTH and not inRTH[1]
lateSession = not na(time(timeframe.period, "1500-1600", "America/New_York"))

// ── Opening Range Tracking ──────────────────────────────────────────
var float orHigh = na
var float orLow  = na
var bool  orDefined = false
var int   orBarsNeeded = 0
var int   orBarsCount = 0
var bool  tradedToday = false
var bool  ordersPlaced = false

// Reset at session open
if isNewSession
    orHigh := high
    orLow  := low
    orDefined := false
    orBarsNeeded := math.ceil(orMinutes * 60.0 / timeframe.in_seconds())
    orBarsCount := 1
    tradedToday := false
    ordersPlaced := false
    strategy.cancel_all()

// Build the opening range during the first N minutes
if inRTH and not orDefined and not isNewSession and orBarsCount < orBarsNeeded
    orHigh := math.max(nz(orHigh, high), high)
    orLow  := math.min(nz(orLow, low), low)
    orBarsCount += 1

// Lock the range after N minutes
if inRTH and not orDefined and orBarsCount >= orBarsNeeded
    orHigh := math.max(nz(orHigh, high), high)
    orLow  := math.min(nz(orLow, low), low)
    orDefined := true

// ── OR Range ────────────────────────────────────────────────────────
orRange = orDefined ? orHigh - orLow : na

// ── Place Stop Orders at OR Levels (once per day) ───────────────────
if orDefined and not ordersPlaced and not tradedToday and inRTH and not lateSession
    if not na(orRange) and orRange > 0 and orRange <= maxSlPts
        riskPerContract = orRange * syminfo.pointvalue
        budget = strategy.equity * riskPct
        qty = math.max(1, math.floor(budget / riskPerContract))

        tpLong  = orHigh + orRange * tpRatio
        tpShort = orLow  - orRange * tpRatio

        strategy.entry("Long",  strategy.long,  stop=orHigh, qty=qty, oca_name="ORB", oca_type=strategy.oca.cancel)
        strategy.exit("Long Exit", "Long", stop=orLow, limit=tpLong)

        strategy.entry("Short", strategy.short, stop=orLow,  qty=qty, oca_name="ORB", oca_type=strategy.oca.cancel)
        strategy.exit("Short Exit", "Short", stop=orHigh, limit=tpShort)

        ordersPlaced := true

// ── Track Fills ─────────────────────────────────────────────────────
if strategy.position_size > 0 and not tradedToday
    tradedToday := true
    label.new(bar_index, low, "LONG", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if strategy.position_size < 0 and not tradedToday
    tradedToday := true
    label.new(bar_index, high, "SHORT", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)

// ── Cancel Unfilled Orders Late in Session ──────────────────────────
if lateSession and strategy.position_size == 0 and ordersPlaced
    strategy.cancel_all()

// ── Close at Session End ────────────────────────────────────────────
if inRTH[1] and not inRTH and strategy.position_size != 0
    strategy.close_all("Session End")

// ── Draw Opening Range ──────────────────────────────────────────────
plot(orDefined and inRTH ? orHigh : na, "OR High", color=color.orange, linewidth=2, style=plot.style_linebr)
plot(orDefined and inRTH ? orLow : na, "OR Low", color=color.orange, linewidth=2, style=plot.style_linebr)
bgcolor(inRTH and not orDefined ? color.new(color.orange, 90) : na)

// ── Stats Table ─────────────────────────────────────────────────────
if barstate.islast
    totalTrades = strategy.closedtrades, wins = strategy.wintrades, losses = strategy.losstrades
    winRate = totalTrades > 0 ? (wins / totalTrades) * 100 : 0.0
    netProfit = strategy.netprofit, profitFactor = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : 0.0
    avgWin = wins > 0 ? strategy.grossprofit / wins : 0.0
    avgLoss = losses > 0 ? math.abs(strategy.grossloss) / losses : 0.0
    returnPct = strategy.initial_capital > 0 ? (netProfit / strategy.initial_capital) * 100 : 0.0
    var table st = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 20), border_width=1)
    table.cell(st, 0, 0, "ORB NQ", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.gray, 40))
    table.cell(st, 1, 0, "", bgcolor=color.new(color.gray, 40))
    table.cell(st, 0, 1, "Trades", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 1, str.tostring(totalTrades), text_color=color.white, text_size=size.small)
    table.cell(st, 0, 2, "Win Rate", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 2, str.tostring(winRate, "#.#") + "%", text_color=winRate >= 50 ? color.green : color.red, text_size=size.small)
    table.cell(st, 0, 3, "Net P&L", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 3, "$" + str.tostring(netProfit, "#.##"), text_color=netProfit >= 0 ? color.green : color.red, text_size=size.small)
    table.cell(st, 0, 4, "Profit Factor", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 4, str.tostring(profitFactor, "#.##"), text_color=profitFactor >= 1 ? color.green : color.red, text_size=size.small)
    table.cell(st, 0, 5, "Max DD", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 5, "$" + str.tostring(strategy.max_drawdown, "#.##"), text_color=color.red, text_size=size.small)
    table.cell(st, 0, 6, "Avg Win", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 6, "$" + str.tostring(avgWin, "#.##"), text_color=color.green, text_size=size.small)
    table.cell(st, 0, 7, "Avg Loss", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 7, "$" + str.tostring(avgLoss, "#.##"), text_color=color.red, text_size=size.small)
    table.cell(st, 0, 8, "Return", text_color=color.white, text_size=size.small)
    table.cell(st, 1, 8, str.tostring(returnPct, "#.#") + "%", text_color=returnPct >= 0 ? color.green : color.red, text_size=size.small)
